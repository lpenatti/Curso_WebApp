@model IEnumerable<Projeto02.AppWebForum.Models.ForumUsuarioComentariosDTO>

@{
    ViewData["Title"] = "Listar Comentarios por Forum";
}

<h1>Listar Comentários por Forum</h1>

<p>
    @using (Html.BeginForm("ListarComentarios", "Comentarios", FormMethod.Get))
    {
        <div class="mb-3">
            @Html.Label("forum", "Escolha o forum")
            @Html.DropDownList(
                "idForum", 
                (SelectList)ViewBag.Foruns, 
                "SELECIONE O FÓRUM", 
                new { @class="form-select"})
        </div>
        <div class="mb-3">
            <input type="submit" value="Buscar" class="btn btn-primary"/>
        </div>
    }
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.IdComentario)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.DescricaoForum)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.NomeUsuario)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Comentario)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.DataComentario)
            </th>
            
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.IdComentario)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.DescricaoForum)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.NomeUsuario)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Comentario)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.DataComentario)
            </td>

        </tr>
}
    </tbody>
</table>
